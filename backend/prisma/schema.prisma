generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model categories {
  id            Int             @id @default(autoincrement())
  name          String?         @db.VarChar(250)
  createdAt     DateTime?       @default(now()) @db.DateTime(0)
  subscriptions subscriptions[]
}

model departments {
  id            Int             @id @default(autoincrement())
  name          String?         @db.VarChar(250)
  createdAt     DateTime?       @default(now()) @db.DateTime(0)
  subscriptions subscriptions[]
}

model roles {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @db.DateTime(0)
  users     users[]
}

model subscriptions {
  id               Int         @id @default(autoincrement())
  name             String      @db.VarChar(250)
  categoryId       Int
  licensePrice     Decimal     @db.Decimal(10, 2)
  numberOfLicenses Int
  departmentId     Int
  usagePercent     Int
  description      String?     @db.VarChar(500)
  userId           Int?
  updatedAt        DateTime    @default(now()) @db.DateTime(0)
  createdAt        DateTime    @default(now()) @db.DateTime(0)
  categories       categories  @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "subscriptions_ibfk_1")
  departments      departments @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "subscriptions_ibfk_2")
  users            users?      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "subscriptions_ibfk_3")

  @@index([categoryId], map: "categoryId")
  @@index([departmentId], map: "departmentId")
  @@index([userId], map: "userId")
}

model users {
  id            Int             @id @default(autoincrement())
  username      String          @db.VarChar(100)
  password      String          @db.VarChar(500)
  roleId        Int
  createdAt     DateTime        @default(now()) @db.DateTime(0)
  subscriptions subscriptions[]
  roles         roles           @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "users_ibfk_1")

  @@index([roleId], map: "roleId")
}
